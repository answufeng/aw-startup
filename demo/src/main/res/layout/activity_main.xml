<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?android:attr/colorPrimary"
            app:title="🚀 aw-startup 启动库"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_startup" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 启动报告卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📊 启动报告"
                        android:textColor="#673AB7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_report"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="查看应用启动时的任务执行情况，包括耗时、优先级、状态等详细信息"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnReport"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="查看报告"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAwait"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="等待任务" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 依赖关系演示卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔗 依赖关系"
                        android:textColor="#673AB7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_dependency"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="演示任务之间的依赖关系，确保任务按正确的顺序执行（TaskA → TaskB → TaskC）"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/btnRegisterDependency"
                        style="@style/MaterialButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="演示依赖关系" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 优先级演示卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔍 优先级管理"
                        android:textColor="#673AB7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_priority"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="演示不同优先级任务的执行顺序：CRITICAL > HIGH > NORMAL > LOW"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/btnRegisterPriority"
                        style="@style/MaterialButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="演示优先级" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 错误处理演示卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠️ 错误处理"
                        android:textColor="#673AB7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_error"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="演示任务失败时的处理策略，支持跳过失败任务继续执行其他任务"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/btnRegisterError"
                        style="@style/MaterialButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="演示错误处理" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 操作日志卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋 操作日志"
                        android:textColor="#673AB7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_logs"
                        android:layout_marginBottom="12dp" />

                    <ScrollView
                        android:id="@+id/logScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="#F8F9FA"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="操作日志将显示在这里...\n点击上方按钮开始测试启动功能"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />

                    </ScrollView>

                    <Button
                        android:id="@+id/btnClearLog"
                        style="@style/MaterialButton.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_gravity="end"
                        android:text="清除日志"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
